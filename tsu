#!/usr/bin/env bash
# TSUNAMI — Reborn from the Flood
DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
PYTHON_BIN="$DIR/.venv/bin/python"
if [ ! -x "$PYTHON_BIN" ]; then
  PYTHON_BIN="$(command -v python3 || true)"
fi

TSUNAMI_DOCKER_BACKEND="${TSUNAMI_DOCKER_BACKEND:-auto}"
TSUNAMI_DOCKER_IMAGE="${TSUNAMI_DOCKER_IMAGE:-tsunami-exec:latest}"
TSUNAMI_DOCKER_ROOT="${TSUNAMI_DOCKER_ROOT:-/workspace/tsunami}"
TSUNAMI_DOCKER_REBUILD="${TSUNAMI_DOCKER_REBUILD:-0}"
TSUNAMI_CTX_SIZE="${TSUNAMI_CTX_SIZE:-32768}"
STARTED_DOCKER_BACKEND=0

if [ -z "$PYTHON_BIN" ]; then
  echo "python3 not found. Run ./setup.sh first." >&2
  exit 1
fi

cd "$DIR"

detect_ram_gb() {
  local ram
  ram="$(free -g 2>/dev/null | awk '/^Mem:/{print $2}' || true)"
  if [ -n "$ram" ]; then
    echo "$ram"
    return
  fi
  ram="$(sysctl -n hw.memsize 2>/dev/null | awk '{print int($1/1073741824)}' || true)"
  if [ -n "$ram" ]; then
    echo "$ram"
    return
  fi
  echo 0
}

docker_backend_requested() {
  case "$TSUNAMI_DOCKER_BACKEND" in
    0|false|no|off|disabled) return 1 ;;
    *) command -v docker >/dev/null 2>&1 ;;
  esac
}

docker_container_name() {
  local digest
  if command -v sha1sum >/dev/null 2>&1; then
    digest="$(printf '%s' "$DIR" | sha1sum | awk '{print substr($1,1,12)}')"
  else
    digest="$(printf '%s' "$DIR" | shasum | awk '{print substr($1,1,12)}')"
  fi
  printf 'tsunami-exec-%s' "$digest"
}

docker_container_running() {
  docker inspect -f '{{.State.Running}}' "$(docker_container_name)" 2>/dev/null | grep -q '^true$'
}

docker_container_logs_indicate_ready() {
  docker logs "$(docker_container_name)" 2>&1 | grep -q 'Uvicorn running on http://0.0.0.0:3000'
}

resolve_model_path() {
  local requested="$1"
  [ -n "$requested" ] || return 1

  if [ -f "$requested" ]; then
    printf '%s\n' "$requested"
    return 0
  fi

  if [ -f "models/$requested" ]; then
    printf '%s\n' "models/$requested"
    return 0
  fi

  return 1
}

resolve_mmproj_for_model() {
  local model_path="$1"
  case "$(basename "$model_path")" in
    *27B*)
      ls models/mmproj-27B*.gguf models/mmproj-BF16.gguf models/mmproj-F16.gguf 2>/dev/null | head -1
      ;;
    *9B*|*8B*)
      ls models/mmproj-9B-BF16.gguf models/mmproj-BF16.gguf models/mmproj-F16.gguf 2>/dev/null | head -1
      ;;
    *2B*)
      ls models/mmproj-2B-BF16.gguf models/mmproj-BF16.gguf models/mmproj-F16.gguf 2>/dev/null | head -1
      ;;
    *)
      ls models/mmproj-BF16.gguf models/mmproj-F16.gguf models/mmproj-9B-BF16.gguf models/mmproj-27B*.gguf models/mmproj-2B-BF16.gguf 2>/dev/null | head -1
      ;;
  esac
}

ensure_docker_image() {
  if [ "$TSUNAMI_DOCKER_REBUILD" != "1" ] && docker image inspect "$TSUNAMI_DOCKER_IMAGE" >/dev/null 2>&1; then
    return 0
  fi
  echo "  building Docker backend image: $TSUNAMI_DOCKER_IMAGE"
  docker build --progress=plain -t "$TSUNAMI_DOCKER_IMAGE" -f "$DIR/docker/exec.Dockerfile" "$DIR"
}

docker_port_publish_args() {
  local port args=()
  args+=(-p 3000:3000)

  for port in 4173 5173 8000 8080 9876; do
    if lsof -ti "tcp:${port}" >/dev/null 2>&1; then
      echo "  docker backend: leaving host port :${port} untouched (already in use)" >&2
      continue
    fi
    args+=(-p "${port}:${port}")
  done

  printf '%s\n' "${args[@]}"
}

start_docker_backend() {
  local container_name backend_model_endpoint backend_bee_endpoint
  local -a port_args
  local port_arg
  container_name="$(docker_container_name)"
  ensure_docker_image || return 1
  docker rm -f "$container_name" >/dev/null 2>&1 || true

  backend_model_endpoint="http://host.docker.internal:8090"
  backend_bee_endpoint="http://host.docker.internal:${BEE_ENDPOINT##*:}"
  while IFS= read -r port_arg; do
    [ -n "$port_arg" ] && port_args+=("$port_arg")
  done < <(docker_port_publish_args)

  docker run -d --rm \
    --name "$container_name" \
    --add-host host.docker.internal:host-gateway \
    "${port_args[@]}" \
    -v "$DIR/workspace:$TSUNAMI_DOCKER_ROOT/workspace" \
    -e TSUNAMI_IN_DOCKER=1 \
    -e TSUNAMI_DOCKER_EXEC=0 \
    -e TSUNAMI_WORKSPACE="$TSUNAMI_DOCKER_ROOT/workspace" \
    -e TSUNAMI_MODEL_ENDPOINT="$backend_model_endpoint" \
    -e TSUNAMI_WATCHER_ENDPOINT="$backend_bee_endpoint" \
    -e TSUNAMI_BEE_ENDPOINT="$backend_bee_endpoint" \
    -e TSUNAMI_ACTIVE_MODEL_NAME="${TSUNAMI_ACTIVE_MODEL_NAME:-}" \
    -e TSUNAMI_ACTIVE_WATCHER_MODEL_NAME="${TSUNAMI_ACTIVE_WATCHER_MODEL_NAME:-}" \
    -e TSUNAMI_MAX_TOKENS="${TSUNAMI_MAX_TOKENS:-1024}" \
    "$TSUNAMI_DOCKER_IMAGE" \
    python3 -c "from tsunami.server import start_server; start_server(host='0.0.0.0', port=3000)" \
    >/tmp/tsunami_docker_backend.log 2>&1 || return 1

  STARTED_DOCKER_BACKEND=1
  return 0
}

wait_for_health() {
  local port="$1"
  local tries="${2:-60}"
  local log_file="${3:-}"
  local pid="${4:-}"
  local label="${5:-server}"
  local last_line=""
  local line=""

  for _ in $(seq 1 "$tries"); do
    if curl -sf "http://localhost:${port}/health" > /dev/null 2>&1; then
      [ -n "$last_line" ] && echo "  ${label} ready on :${port}"
      return 0
    fi

    if [ -n "$log_file" ] && [ -f "$log_file" ]; then
      line="$(
        awk '
          /loading model|loaded meta data|offload|offloading|CUDA|Metal|listening|error|failed|context|KV|slot|cache|warming|initializing/ {
            last=$0
          }
          END {
            if (last != "") print last
          }
        ' "$log_file" 2>/dev/null
      )"
      if [ -n "$line" ] && [ "$line" != "$last_line" ]; then
        echo "  ${label}: $line"
        last_line="$line"
      fi
    fi

    if [ -n "$pid" ] && ! kill -0 "$pid" 2>/dev/null; then
      if [ -f "$log_file" ]; then
        line="$(tail -n 5 "$log_file" 2>/dev/null | awk 'NF{last=$0} END{print last}')"
        [ -n "$line" ] && echo "  ${label} exited: $line"
      fi
      return 1
    fi

    sleep 1
  done
  return 1
}

clear_stale_llama_port() {
  local port="$1"
  local had_pid=0
  local pid proc_details listener_snapshot

  for pid in $(lsof -ti "tcp:${port}" 2>/dev/null || true); do
    had_pid=1
    proc_details="$(lsof -nP -p "$pid" 2>/dev/null || true)"
    listener_snapshot="$(lsof -nP -iTCP:${port} -sTCP:LISTEN 2>/dev/null || true)"

    if [ -z "$proc_details" ] && [ -z "$listener_snapshot" ]; then
      # Port cleared between probes — nothing to do.
      continue
    fi

    if echo "$proc_details"$'\n'"$listener_snapshot" | grep -Eq "/llama-server|^llama-ser[[:space:]]"; then
      echo "  replacing stale llama-server on :${port} (pid ${pid})"
      kill "$pid" 2>/dev/null || true
    else
      echo "  port :${port} is occupied by a non-llama process; leaving it alone"
      return 1
    fi
  done

  if [ "$had_pid" = "1" ]; then
    sleep 1
  fi
  return 0
}

start_llama_server() {
  local port="$1"
  local model_path="$2"
  local mmproj_path="$3"
  local cache_k="$4"
  local cache_v="$5"
  local extra_args=()
  local parallel="${TSUNAMI_LLAMA_PARALLEL:-1}"

  [ -n "$model_path" ] || return 1
  [ -x "$LLAMA" ] || return 1

  if [ -n "$mmproj_path" ]; then
    extra_args+=(--mmproj "$mmproj_path")
  fi
  if [ -n "$cache_k" ]; then
    extra_args+=(--cache-type-k "$cache_k")
  fi
  if [ -n "$cache_v" ]; then
    extra_args+=(--cache-type-v "$cache_v")
  fi

  "$LLAMA" --model "$model_path" "${extra_args[@]}" \
    --host 0.0.0.0 --port "$port" \
    --parallel "$parallel" \
    --ctx-size "$TSUNAMI_CTX_SIZE" --n-gpu-layers 99 -fa on \
    --jinja --chat-template-kwargs '{"enable_thinking":false}' \
    > "/tmp/llama-server-${port}.log" 2>&1 &
  echo $!
}

# Handle commands
case "${1:-}" in
  update)
    echo "  Updating Tsunami..."
    git pull --ff-only && echo "  ✓ Updated to $(git rev-parse --short HEAD)" || echo "  ✗ Update failed"
    exit 0
    ;;
  version)
    echo "Tsunami $(git rev-parse --short HEAD) ($(git log -1 --format=%ci | cut -d' ' -f1))"
    exit 0
    ;;
  swarm)
    shift
    TASK="${1:?Usage: tsunami swarm \"task description\" [num_workers]}"
    WORKERS="${2:-2}"
    "$PYTHON_BIN" -m tsunami.orchestrate "$TASK" "$WORKERS"
    exit $?
    ;;
esac

# Check model server
check_model() { curl -sf http://localhost:8090/health > /dev/null 2>&1; }

BEE_ENDPOINT="${TSUNAMI_BEE_ENDPOINT:-http://localhost:8090}"
export TSUNAMI_MODEL_ENDPOINT="http://localhost:8090"
export TSUNAMI_WATCHER_ENDPOINT="$BEE_ENDPOINT"
export TSUNAMI_BEE_ENDPOINT="$BEE_ENDPOINT"
export TSUNAMI_MAX_TOKENS="${TSUNAMI_MAX_TOKENS:-1024}"
export TSUNAMI_TEMPERATURE="${TSUNAMI_TEMPERATURE:-0.2}"
export TSUNAMI_TOP_P="${TSUNAMI_TOP_P:-0.8}"
export TSUNAMI_PRESENCE_PENALTY="${TSUNAMI_PRESENCE_PENALTY:-0.0}"
export TSUNAMI_ACTIVE_MODEL_NAME=""
export TSUNAMI_ACTIVE_WATCHER_MODEL_NAME=""

if ! check_model; then
  clear_stale_llama_port 8090 || true

  # Find llama-server — check common locations
  LLAMA=""
  for p in \
    "$DIR/llama.cpp/build/bin/llama-server" \
    "$(command -v llama-server 2>/dev/null || true)" \
    "$HOME/llama.cpp/build/bin/llama-server" \
    "/usr/local/bin/llama-server" \
    "$HOME/vscode/signet/forge/llama.cpp/build/bin/llama-server"; do
    [ -x "$p" ] && LLAMA="$p" && break
  done

  if [ -z "$LLAMA" ]; then
    echo "  llama-server not found; expected $DIR/llama.cpp/build/bin/llama-server or a PATH install"
  fi

  RAM_GB="$(detect_ram_gb)"
  FORCE_SMALL="${TSUNAMI_FORCE_SMALL_MODEL:-0}"

  # Model priority:
  # - explicit override wins
  # - prefer 9B/8B class if present
  # - otherwise prefer 27B over 2B on machines with enough RAM
  DENSE_27B=$(ls models/Qwen3.5-27B*.gguf 2>/dev/null | head -1)
  MOE_MODEL=$(ls models/*122B*-00001-of-*.gguf 2>/dev/null | head -1)
  TEXT_9B=$(ls models/Qwen3*-9B*.gguf 2>/dev/null | head -1)
  TEXT_8B=$(ls models/Qwen3*-8B*.gguf 2>/dev/null | head -1)
  TEXT_2B=$(ls models/Qwen3*-2B*.gguf 2>/dev/null | head -1)
  MEDIUM_TEXT="${TEXT_9B:-$TEXT_8B}"
  TEXT_MODEL="${MEDIUM_TEXT:-$TEXT_2B}"

  PREFERRED_WAVE=""
  WAVE_MMPROJ=""
  WAVE_CACHE_K=""
  WAVE_CACHE_V=""
  WAVE_OVERRIDE="${TSUNAMI_WAVE_MODEL:-}"
  BEE_OVERRIDE="${TSUNAMI_BEE_MODEL:-}"

  if [ -n "$WAVE_OVERRIDE" ]; then
    PREFERRED_WAVE="$(resolve_model_path "$WAVE_OVERRIDE")"
    if [ -z "$PREFERRED_WAVE" ]; then
      echo "  requested wave model not found: $WAVE_OVERRIDE"
      exit 1
    fi
    WAVE_MMPROJ="$(resolve_mmproj_for_model "$PREFERRED_WAVE")"
    case "$(basename "$PREFERRED_WAVE")" in
      *27B*)
        WAVE_CACHE_K="bf16"
        WAVE_CACHE_V="bf16"
        ;;
    esac
  elif [ "$FORCE_SMALL" = "1" ] && [ -n "$TEXT_2B" ]; then
    PREFERRED_WAVE="$TEXT_2B"
    WAVE_MMPROJ="$(resolve_mmproj_for_model "$PREFERRED_WAVE")"
  elif [ -n "$MEDIUM_TEXT" ]; then
    PREFERRED_WAVE="$MEDIUM_TEXT"
    WAVE_MMPROJ="$(resolve_mmproj_for_model "$PREFERRED_WAVE")"
  elif [ -n "$DENSE_27B" ] && [ "$RAM_GB" -ge 32 ] 2>/dev/null; then
    PREFERRED_WAVE="$DENSE_27B"
    WAVE_MMPROJ="$(resolve_mmproj_for_model "$PREFERRED_WAVE")"
    WAVE_CACHE_K="bf16"
    WAVE_CACHE_V="bf16"
  elif [ -n "$DENSE_27B" ]; then
    PREFERRED_WAVE="$DENSE_27B"
    WAVE_MMPROJ="$(resolve_mmproj_for_model "$PREFERRED_WAVE")"
    WAVE_CACHE_K="bf16"
    WAVE_CACHE_V="bf16"
  elif [ -n "$TEXT_2B" ]; then
    PREFERRED_WAVE="$TEXT_2B"
    WAVE_MMPROJ="$(resolve_mmproj_for_model "$PREFERRED_WAVE")"
  fi

  if [ -n "$MOE_MODEL" ] && [ -f "$LLAMA" ] && [ -z "$PREFERRED_WAVE" ]; then
    echo "  starting 122B MoE: $(basename $MOE_MODEL)"
    "$LLAMA" --model "$MOE_MODEL" \
      --host 0.0.0.0 --port 8090 \
      --ctx-size 16384 --n-gpu-layers 99 -fa on \
      --cache-type-k q8_0 --cache-type-v q8_0 \
      > /tmp/llama-server-8090.log 2>&1 &
    MODEL_PID=$!
    export TSUNAMI_ACTIVE_MODEL_NAME="$(basename "$MOE_MODEL")"
  elif [ -n "$PREFERRED_WAVE" ] && [ -f "$LLAMA" ]; then
    echo "  starting wave on :8090 -> $(basename "$PREFERRED_WAVE")"
    MODEL_PID="$(start_llama_server 8090 "$PREFERRED_WAVE" "$WAVE_MMPROJ" "$WAVE_CACHE_K" "$WAVE_CACHE_V")"
    export TSUNAMI_ACTIVE_MODEL_NAME="$(basename "$PREFERRED_WAVE")"
  fi

  if [ -n "$MODEL_PID" ]; then
    echo "  waiting for wave to load..."
    if ! wait_for_health 8090 120 "/tmp/llama-server-8090.log" "${MODEL_PID:-}" "wave"; then
      if [ -n "$DENSE_27B" ] && [ "$PREFERRED_WAVE" = "$DENSE_27B" ] && [ -n "$TEXT_MODEL" ]; then
        kill "$MODEL_PID" 2>/dev/null || true
        echo "  27B wave failed to load; falling back to $(basename "$TEXT_MODEL")"
        MODEL_PID="$(start_llama_server 8090 "$TEXT_MODEL" "$(resolve_mmproj_for_model "$TEXT_MODEL")" "" "")"
        export TSUNAMI_ACTIVE_MODEL_NAME="$(basename "$TEXT_MODEL")"
        if ! wait_for_health 8090 120 "/tmp/llama-server-8090.log" "${MODEL_PID:-}" "wave"; then
          echo "  local model failed to come up on :8090; see /tmp/llama-server-8090.log"
        fi
      else
        echo "  local model failed to come up on :8090; see /tmp/llama-server-8090.log"
      fi
    fi
  fi

  # Dedicated eddy model on :8092 when possible, otherwise route helper traffic to :8090.
  if curl -sf http://localhost:8090/health > /dev/null 2>&1; then
    BEE_MODEL=""
    if [ -n "$BEE_OVERRIDE" ]; then
      BEE_MODEL="$(resolve_model_path "$BEE_OVERRIDE")"
      if [ -z "$BEE_MODEL" ]; then
        echo "  requested eddy model not found: $BEE_OVERRIDE"
        exit 1
      fi
    elif [ -n "$TEXT_2B" ] && [ "$PREFERRED_WAVE" != "$TEXT_2B" ]; then
      BEE_MODEL="$TEXT_2B"
    elif [ -n "$TEXT_MODEL" ] && [ "$PREFERRED_WAVE" != "$TEXT_MODEL" ]; then
      BEE_MODEL="$TEXT_MODEL"
    fi

    if [ -n "$BEE_MODEL" ] && [ -f "$LLAMA" ]; then
      clear_stale_llama_port 8092 || true
      echo "  starting eddy on :8092 -> $(basename "$BEE_MODEL")"
      BEE_PID="$(start_llama_server 8092 "$BEE_MODEL" "$(resolve_mmproj_for_model "$BEE_MODEL")" "" "")"
      if wait_for_health 8092 60 "/tmp/llama-server-8092.log" "${BEE_PID:-}" "eddy"; then
        BEE_ENDPOINT="http://localhost:8092"
        export TSUNAMI_ACTIVE_WATCHER_MODEL_NAME="$(basename "$BEE_MODEL")"
      else
        kill "$BEE_PID" 2>/dev/null || true
        BEE_PID=""
        BEE_ENDPOINT="http://localhost:8090"
        export TSUNAMI_ACTIVE_WATCHER_MODEL_NAME="${TSUNAMI_ACTIVE_MODEL_NAME}"
      fi
    else
      BEE_ENDPOINT="http://localhost:8090"
      export TSUNAMI_ACTIVE_WATCHER_MODEL_NAME="${TSUNAMI_ACTIVE_MODEL_NAME}"
    fi
  fi
fi

export TSUNAMI_MODEL_ENDPOINT="http://localhost:8090"
export TSUNAMI_WATCHER_ENDPOINT="$BEE_ENDPOINT"
export TSUNAMI_BEE_ENDPOINT="$BEE_ENDPOINT"
if [ -z "${TSUNAMI_ACTIVE_WATCHER_MODEL_NAME:-}" ]; then
  export TSUNAMI_ACTIVE_WATCHER_MODEL_NAME="${TSUNAMI_ACTIVE_MODEL_NAME}"
fi

# Start Python WebSocket backend if not running
BACKEND_READY=0
if docker_backend_requested; then
  if curl -sf http://localhost:3000/api/health > /dev/null 2>&1 && ! docker_container_running; then
    if [ -f /tmp/tsunami_server.pid ]; then
      EXISTING_SERVER_PID="$(cat /tmp/tsunami_server.pid 2>/dev/null || true)"
      if [ -n "$EXISTING_SERVER_PID" ]; then
        kill "$EXISTING_SERVER_PID" 2>/dev/null || true
        sleep 1
      fi
    fi
  fi
elif curl -sf http://localhost:3000/api/health > /dev/null 2>&1; then
  # If a stale backend is running without WebSocket support, stop it so this launcher
  # can restart the server from the current virtualenv.
  if [ -f /tmp/tsunami_server.pid ]; then
    EXISTING_SERVER_PID="$(cat /tmp/tsunami_server.pid 2>/dev/null || true)"
    if [ -n "$EXISTING_SERVER_PID" ]; then
      kill "$EXISTING_SERVER_PID" 2>/dev/null || true
      sleep 1
    fi
  fi
fi

if ! curl -sf http://localhost:3000/api/health > /dev/null 2>&1; then
  if docker_backend_requested; then
    echo "  starting tsunami backend in Docker on :3000"
    if start_docker_backend; then
      for i in $(seq 1 20); do
        if curl -sf http://localhost:3000/api/health > /dev/null 2>&1; then
          BACKEND_READY=1
          break
        fi
        if docker_container_running && docker_container_logs_indicate_ready; then
          BACKEND_READY=1
          break
        fi
        sleep 0.5
      done
    fi
  else
    "$PYTHON_BIN" -c "
import sys; sys.path.insert(0,'$DIR')
from tsunami.server import start_server
start_server(host='0.0.0.0', port=3000)
" > /tmp/tsunami_server.log 2>&1 &
    SERVER_PID=$!
    echo "$SERVER_PID" > /tmp/tsunami_server.pid
    for i in $(seq 1 10); do
      if curl -sf http://localhost:3000/api/health > /dev/null 2>&1; then
        BACKEND_READY=1
        break
      fi
      sleep 0.5
    done
  fi
else
  BACKEND_READY=1
fi

cleanup() {
  [ -n "${SERVER_PID:-}" ] && kill "$SERVER_PID" 2>/dev/null
  [ -n "${MODEL_PID:-}" ] && kill "$MODEL_PID" 2>/dev/null
  [ -n "${BEE_PID:-}" ] && kill "$BEE_PID" 2>/dev/null
  if [ "$STARTED_DOCKER_BACKEND" = "1" ]; then
    docker rm -f "$(docker_container_name)" >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

# Launch frontend — prefer the built Ink CLI bundle, fall back to tsx for development.
if [ -f "$DIR/cli/dist/tsunami.cjs" ] && [ "$BACKEND_READY" = "1" ]; then
  if docker_backend_requested && docker_container_running; then
    echo "  launching Tsunami UI (bundle)"
  fi
  cd "$DIR/cli"
  exec node "$DIR/cli/dist/tsunami.cjs" "$@"
elif [ -x "$DIR/cli/node_modules/.bin/tsx" ] && [ "$BACKEND_READY" = "1" ]; then
  if docker_backend_requested && docker_container_running; then
    echo "  launching Tsunami UI (tsx)"
  fi
  cd "$DIR/cli"
  exec "$DIR/cli/node_modules/.bin/tsx" app.jsx "$@"
else
  if [ -x "$DIR/cli/node_modules/.bin/tsx" ] && [ "$BACKEND_READY" != "1" ]; then
    echo "  backend failed to start; falling back to Python REPL"
    if [ -f /tmp/tsunami_server.log ]; then
      echo "  see /tmp/tsunami_server.log for details"
    fi
  fi
  # Python fallback — simple REPL that talks to the agent
  cd "$DIR"
  exec "$PYTHON_BIN" -c "
import sys, asyncio
sys.path.insert(0, '$DIR')
from tsunami.agent import Agent
from tsunami.config import TsunamiConfig

async def main():
    config = TsunamiConfig.from_yaml('config.yaml')
    config = TsunamiConfig.from_env(config)
    agent = Agent(config)
    print('TSUNAMI — type a task, press Enter. Type exit to quit.')
    print()
    while True:
        try:
            task = input('> ')
        except (EOFError, KeyboardInterrupt):
            break
        if task.strip().lower() in ('exit', 'quit', 'q'):
            break
        if not task.strip():
            continue
        result = await agent.run(task)
        print(result)
        print()

asyncio.run(main())
"
fi
